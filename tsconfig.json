{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "ES2023"],
    "module": "commonjs",
    "outDir": "./lib",
    "useUnknownInCatchVariables":false,
    "rootDir": "./src",
    "strict": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "types": ["node", "jest"]
  },
  "exclude": ["node_modules", "**/*.test.ts"]
}
